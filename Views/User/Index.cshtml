@model List<AssetTrack.Models.User>

@{
    ViewData["Title"] = "User";
}

<h2 class="mb-4 fw-bold">
    Manajemen User
</h2>

<div class="card shadow-sm border-0 rounded-4 p-4">

    <!-- SEARCH + BUTTON -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <!-- SEARCH -->
        <form method="get" class="d-flex" style="width: 300px;">
            <input type="text"
                id="searchBox"
                name="search"
                class="form-control"
                placeholder="Cari user..."
                value="@Context.Request.Query["search"]" />
        </form>

        <!-- BUTTON TAMBAH -->
        <a asp-action="Create"
        class="btn d-flex align-items-center gap-2"
        style="background:#198754; color:white; border:none;">
            <span class="iconify" data-icon="ic:outline-plus"></span>
            Tambah User
        </a>
    </div>

    <!--TABLE-->
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>No</th>
                <th>Nama</th>
                <th>Username</th>
                <th>Role</th>
                <th width="180">Aksi</th>
            </tr>
        </thead>
        <tbody>
            @{
                int no = 1;
            }
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@no</td>
                        <td>@(item.Nama ?? "-")</td>
                        <td>@(item.Username ?? "-")</td>
                        <td>
                            @if ((item.Role ?? "") == "Admin")
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">User</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit"
                            asp-route-id="@item.Id"
                            class="btn btn-warning btn-sm">Edit</a>

                            <a asp-action="Delete"
                            asp-route-id="@item.Id"
                            class="btn btn-danger btn-sm btn-delete">Hapus</a>
                        </td>
                    </tr>
                    no++;
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">Belum ada data user</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        // DELETE CONFIRM
        document.querySelectorAll('.btn-delete').forEach(button => {
            button.addEventListener('click', function (e) {
                e.preventDefault();

                const url = this.href;

                Swal.fire({
                    title: 'Hapus User?',
                    text: 'Data yang dihapus tidak dapat dikembalikan.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Ya, Hapus',
                    cancelButtonText: 'Batal'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            });
        });

        // SEARCH (debounce)
        let timeout = null;
        const searchBox = document.getElementById("searchBox");

        if (searchBox) {
            searchBox.addEventListener("keyup", function () {
                clearTimeout(timeout);

                timeout = setTimeout(() => {
                    const value = this.value;
                    window.location.href = `/User/Index?search=${encodeURIComponent(value)}`;
                }, 800);
            });
        }
    });
</script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Berhasil',
            text: '@TempData["Success"]',
            timer: 2000,
            showConfirmButton: false,
            timerProgressBar: true
        });
    </script>
}
