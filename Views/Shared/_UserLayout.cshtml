<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetTrack</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <script src="https://code.iconify.design/2/2.2.1/iconify.min.js"></script>

    <!--Plus Jakarta sans-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #FFFFFF;
            margin: 0;
        }

        /* NAVBAR */
        .navbar {
            margin-left: 220px;
            min-height: 80px;
            display: flex;
            align-items: center;
        }

        .navbar .username-box {
            font-size: 16px;
            font-weight: 600;
            color: #111827;
            background-color: #f3f4f6;
            padding: 6px 12px;
            border-radius: 8px;
        }

        /* SIDEBAR BARU */
        .sidebar {
            width: 220px;
            height: 100vh;
            position: fixed;
            background-color: #43A5A1;
            color: white;
            padding: 20px;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
        }

        .sidebar h4 {
            text-align: center;
            font-size: 30px;
            font-weight: 700;
            margin-top: 0px;
            margin-bottom: 50px;
        }

        .sidebar a {
            color: white;
            display: flex;
            align-items: center;
            margin: 15px 0;
            text-decoration: none;
        }

        .sidebar a.active {
            background-color: #374151;
            padding: 10px;
            border-radius: 10px;
        }
        .sidebar a:hover {
            color: #9ca3af;
        }

        .sidebar a .iconify {
            margin-right: 12px;
            font-size: 20px;
            vertical-align: middle;
        }

        .sidebar .logout {
            margin-top: auto;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            padding: 10px;
            border-radius: 8px;
            background-color:transparent;
            width: 100%;
        }

        /* CONTENT */
        .main-content {
            margin-left: 220px;
        }

    </style>
</head>

<body>
    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="menu">
            <h4>AssetTrack</h4>

            <!-- Fitur khusus user -->
            <a href="/Peminjaman/Index"
               class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Peminjaman" ? "active" : "")">
                <span class="iconify" data-icon="solar:clipboard-check-outline"></span>
                Peminjaman
            </a>
        </div>

        <!-- Logout di bawah -->
        <a href="/Auth/Logout" class="logout">
            <span class="iconify" data-icon="solar:logout-2-outline"></span> Logout
        </a>
    </div>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom px-3">
            <div class="container-fluid">
                <span></span>
                <div class="d-flex align-items-center">
                    @if (Context.Session.GetString("UserUsername") != null)
                    {
                        <span class="username-box">
                            @Context.Session.GetString("UserUsername")
                        </span>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENT -->
    <div class="main-content p-4">
        @RenderBody()
    </div>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>