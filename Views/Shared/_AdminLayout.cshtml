<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetTrack</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <script src="https://code.iconify.design/2/2.2.1/iconify.min.js"></script>

    <!--Plus Jakarta sans-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #FFFFFF;
            margin: 0;
        }

        /* SIDEBAR */
        .sidebar {
            width: 220px;
            height: 100vh;
            position: fixed;
            background-color: #43A5A1;
            color: white;
            padding: 20px;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
        }

        .sidebar .logout {
            margin-top: auto;
            padding: 10px;
            text-decoration: none;
            display: flex;
            align-items: center;
            border-radius: 8px;
            font-weight: 600;
            width: 100%;
            color: white;
            background-color: transparent;
        }

        /sidebar .logout:hover {
            color: #4b5563;
            color: #ffffff;
        }

        .sidebar h4 {
            text-align: center;
            font-size: 30px;
            font-weight: 700;
            margin-top: 0px;
            margin-bottom: 50px;
        }

        .sidebar a {
            color: white;
            display: block;
            margin: 15px 0;
            text-decoration: none;
        }

        /* MENU ACTIVE */
        .sidebar a.active {
            background-color: #374151;
            padding: 10px;
            border-radius: 10px;
        }

        .sidebar a:hover {
            color: #9ca3af;
        }

        .sidebar a {
            display: flex;
            align-items: center;
        }

        .sidebar a .iconify {
            margin-right: 12px;
            font-size: 20px;
            vertical-align: middle;
        }

        /* CONTENT */
        .main-content {
            margin-left: 220px;
        }

        /* NAVBAR */
        .navbar {
            margin-left: 220px;
            min-height: 80px;
            display: flex;
            align-items: center;
        }

    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="menu">
            <h4>AssetTrack</h4>

            <a href="/Dashboard/Index"
                class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <span class="iconify" data-icon="solar:widget-5-outline"></span>
                Dashboard
            </a>
            <a href="/Asset/Index"
               class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Asset" ? "active" : "")">
               <span class="iconify" data-icon="solar:laptop-outline"></span>
                Asset
            </a>
            <a href="/User/Index"
                class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")">
                <span class="iconify" data-icon="solar:users-group-rounded-outline"></span>
                User
            </a>
            <a href="/PeminjamanAdmin/Index"
               class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "PeminjamanAdmin" ? "active" : "")">
                <span class="iconify" data-icon="solar:clipboard-check-outline"></span>
               Peminjaman
            </a>
            <a href="/Pengembalian/Index"
               class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Pengembalian" ? "active" : "")">
                <span class="iconify" data-icon="solar:refresh-outline"></span>
                Pengembalian
            </a>
            <a href="/Laporan/Index"
               class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Laporan" ? "active" : "")">
                <span class="iconify" data-icon="solar:chart-outline"></span>
                Laporan
            </a>
        </div>

        <!--LOGOUT-->
        <a href="/Auth/Logout" class="logout">
            <span class="iconify" data-icon="solar:logout-2-outline"></span>
            Logout
        </a>

    </div>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom px-3">

            <div class="container-fluid">

                <!-- KOSONG KIRI (karena sudah ada sidebar) -->
                <span></span>

                <!-- KANAN (USER + LOGOUT) -->
                <div class="d-flex align-items-center">

                    @if (Context.Session.GetString("UserUsername") != null)
                    {
                        <span class="me-3 fw-semibold">
                            @Context.Session.GetString("UserUsername")
                        </span>
                    }

                </div>

            </div>

        </nav>
    </header>

    <!-- CONTENT -->
    <div class="main-content p-4">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>