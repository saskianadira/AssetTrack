@model AssetTrack.Models.Asset

@{
    ViewData["Title"] = "Tambah Asset";
}

<h2 class="mb-4">Tambah Asset</h2>

<div class="card shadow-sm border-0 rounded-4 p-4">

    <form method="post" enctype="multipart/form-data">

        <div class="mb-3">
            <label>Nama Asset</label>
            <input asp-for="NamaAsset" class="form-control" />
            <span asp-validation-for="NamaAsset" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Kategori</label>
            <input asp-for="Kategori" class="form-control" />
            <span asp-validation-for="Kategori" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Jumlah</label>
            <input asp-for="Jumlah" class="form-control" />
            <span asp-validation-for="Jumlah" class="text-danger"></span>
        </div>

        <div class="d-flex align-items-center gap-3 mb-4">
            <!--PREVIEW FOTO-->
            <div>
                <img id="previewFoto"
                    width="60"
                    height="60"
                    class="rounded shadow-sm"
                    style="display:none; object-fit:cover" />
            </div>

            <!--INPUT FILE-->
            <div style="min-width: 650px;">
                <label class="fw-bold d-block mb-2">
                    Foto Assset
                </label>

                <input type="file"
                    name="fotoFile"
                    id="fotoInput"
                    class="form-control"
                    accept=".jpg,.jpeg,.png" />
                 <span asp-validation-for="Foto" class="text-danger"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-success">
            Simpan
        </button>

        <a asp-controller="Asset"
           asp-action="Index"
           class="btn btn-danger">

            Kembali

        </a>

    </form>

    <script>
        const fotoInput = document.getElementById("fotoInput");
        const previewFoto = document.getElementById("previewFoto");

        fotoInput.addEventListener("change", function () {
            const file = this.files[0];

            if (file)
            {
                const reader = new FileReader();

                reader.onload = function (e)
                {
                    previewFoto.src = e.target.result;
                    previewFoto.style.display = "block";
                }

                reader.readAsDataURL(file);
            }
        });
    </script>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
