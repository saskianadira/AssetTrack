@model List<AssetTrack.Models.Asset>

@{
    ViewData["Title"] = "Asset";
}

<h2 class="mb-4">Data Asset</h2>

<div class="card shadow-sm border-0 rounded-4 p-4">

    <!-- SEARCH + BUTTON -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <!-- SEARCH -->
        <form method="get" class="d-flex" style="width: 300px;">
            <input type="text"
                   name="search"
                   class="form-control"
                   placeholder="Cari asset..."
                   value="@Context.Request.Query["search"]" />
        </form>

        <!-- BUTTON TAMBAH -->
        <a href="/Asset/Create"
           class="btn d-flex align-items-center gap-2"
           style="background: #198754; color:white; border:none;">
            <span class="iconify" data-icon="ic:outline-plus"></span>
            Tambah Asset
        </a>
    </div>

    <!-- TABLE -->
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>No</th>
                <th>Foto</th>
                <th>Nama Asset</th>
                <th>Kategori</th>
                <th>Jumlah</th>
                <th width="180">Action</th>
            </tr>
        </thead>
        <tbody>
            @{
                int no = 1;
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@no</td>
                    <td>
                        <img src="~/images/@item.Foto"
                             width="80"
                             height="80"
                             style="object-fit: cover;"
                             class="rounded" />
                    </td>
                    <td>@item.NamaAsset</td>
                    <td>@item.Kategori</td>
                    <td>@item.Jumlah</td>
                    <td>
                        <a asp-controller="Asset"
                           asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>
                        <a asp-controller="Asset"
                           asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Yakin ingin menghapus asset ini?');">
                            Delete
                        </a>
                    </td>
                </tr>
                no++;
            }
        </tbody>
    </table>
</div>
