@model AssetTrack.Models.Asset

@{
    ViewData["Tittle"] = "Edit Asset";
}

<h2 class="mb-4">Edit Asset</h2>

<div class="card shadow-sm border-0 rounded-4 p-4">

    <form method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label>Nama Asset</label>
            <input asp-for="NamaAsset" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Kategori</label>
            <input asp-for="Kategori" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Jumlah</label>
            <input asp-for="Jumlah" class="form-control" />
        </div>

        <!--GANTI FOTO-->
        <div class="d-flex align-items-center gap-3 mb-4">

            <!--FOTO-->
            <div>
                <img id="previewFoto"
                     src="/images/@Model.Foto"
                     width="60"
                     height="60"
                     class="rounded shadow-sm"
                     style="object-fit: cover;" />
            </div>

            <!--INPUT FILE -->
            <div style="min-width: 650px;">
                <label class="fw-bold mb-2">
                    Ganti Foto
                </label>

                <input type="file"
                    name="fotoFile"
                    id="fotoInput"
                    class="form-control"
                    accept=".jpg,.jpeg,.png" />
            </div>
        </div>

        <button type="submit" class="btn btn-dark">
            Update
        </button>

        <a asp-controller="Asset"
           asp-action="Index"
           class="btn btn-secondary">
           Kembali
        </a>

    </form>

    <script>
        const fotoInput = document.getElementById("fotoInput");
        const previewFoto = document.getElementById("previewFoto");

        fotoInput.addEventListener("change", function () {
            const file = this.files[0];

            if (file)
            {
                const reader = new FileReader();

                reader.onload = function (e)
                {
                    previewFoto.src = e.target.result;
                }

                reader.readAsDataURL(file);
            }
        });
    </script>

</div>