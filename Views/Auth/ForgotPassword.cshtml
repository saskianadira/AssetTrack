@model AssetTrack.Models.ForgotPassword

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Lupa Password - AssetTrack</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .btn-custom {
        background-color: #1E3A8A;
        border-color: #1E3A8A;
        color: white;
        }

        .btn-custom:hover {
        background-color: #1E40AF;
        border-color: #1E40AF;
        color: white;
        }
    </style>
</head>

<body style="background-color:#ffffff;">

    <div class="container d-flex justify-content-center align-items-center vh-100">

        <div class="card shadow p-4 text-center"
        style="width:450px; border-radius:15px; border:none;">

            <h4 class="mb-3">AssetTrack</h4>

            <p class="text-muted mb-4">
                Lupa Password
            </p>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (ViewBag.UserFound == true)
            {
                <!-- FORM RESET PASSWORD -->

                <form method="post" action="/Auth/ResetPassword">

                    <div class="mb-3 text-start">
                        <label>Username</label>
                        <input asp-for="Username"
                        class="form-control"
                        readonly>
                    </div>

                    <div class="mb-3 text-start">
                        <label>Password Baru</label>
                        <input asp-for="NewPassword"
                        type="password"
                        class="form-control"
                        placeholder="Masukkan password baru">
                    </div>

                    <div class="mb-3 text-start">
                        <label>Konfirmasi Password</label>
                        <input asp-for="ConfirmPassword"
                        type="password"
                        class="form-control"
                        placeholder="Konfirmasi password baru">
                    </div>

                    <button type="submit"
                    class="btn btn-custom w-100">
                        Reset Password
                    </button>

                </form>
            }
            else
            {
                <!-- FORM CARI USERNAME -->

                <form method="post">

                    <div class="mb-3 text-start">
                        <label>Username</label>
                        <input asp-for="Username"
                        class="form-control"
                        placeholder="Masukkan username">
                    </div>

                    <button type="submit"
                    class="btn btn-custom w-100">
                        Cari Akun
                    </button>

                </form>
            }

            <div class="mt-4">
                <a href="/Auth/Login"
                class="text-decoration-none fw-semibold">
                    Kembali ke Login
                </a>
            </div>

        </div>

    </div>

</body>
</html>