@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - AssetTrack</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!--Pus Jakarta Sans-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>

        body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .btn-login {
        background-color: #1E3A8A;
        border-color: #1E3A8A;
        color:white;
        }

        .btn-login:hover {
        background-color: #1E40AF;
        border-color: #1E40AF;
        color: white;
        }

    </style>
</head>
<body style="background-color: #ffffff;">

    <div class="container d-flex justify-content-center align-items-center vh-100">

        <div class="card shadow p-4 text-center" style="width: 450px; border-radius: 15px; border: none;">

            <!-- TITLE -->
            <h4 class="mb-3">AssetTrack</h4>
            <p class="text-muted mb-4">Rancang Bangun Sistem Informasi Peminjaman dan Pengembalian Perangkat IT Berbasis Web</p>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <!-- FORM -->
            <form method="post">

                <div class="mb-3 text-start">
                    <label>Username</label>
                    <input type="text" name="username" class="form-control" placeholder="Masukkan username">
                </div>

                <div class="mb-3 text-start">
                    <label>Password</label>
                    <input type="password" name="password" class="form-control" placeholder="Masukkan password">
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Login
                </button>

                <!--Lupa Password-->
                <div class="text-end mt-3 mb-4">
                    <a href="/Auth/ForgotPassword"
                    class="text-decoration-none small">
                        Lupa Password
                    </a>
                </div>

                <!--Registrasi-->
                <div class="mt-4">
                    <span class="text-muted">Belum memiliki akun?</span>
                    <a href="/Auth/Register" class="text-decoration-none fw-semibold">
                        Registrasi    
                    </a>
                </div>

            </form>

            <!-- ERROR -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mt-3">
                    @TempData["Error"]
                </div>
            }

        </div>

    </div>

</body>
</html>